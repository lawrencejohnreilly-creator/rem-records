  "artifact": {
    "title": "HDRP: Hypercube Data Rotation Protocol (Project Rubik's Cube)",
    "author": "Lawrence Reilly",
    "description": "An experimental protocol that distributes erasure-coded data shards across an n-dimensional hypercube topology and periodically rotates their placement using automorphisms of the cube. Each rotation is committed to a verifiable, blockchain-anchorable epoch ledger \u2014 combining fault tolerance, continuous cryptographic auditability, and moving target defense in one storage substrate. Integrates with Project Looking Glass self-healing architecture and Dual-Layer Digital Permanence anchoring. (draft-reilly-hdrp-00)",
    "filename": "draft-reilly-hdrp-00.txt",
    "byte_length": 27939,
